{
  "framework": null,
  "installCommand": "pnpm install --no-frozen-lockfile --ignore-scripts && pnpm rebuild esbuild",
  "buildCommand": "pnpm --filter @workspace/finance-tracker run build && mv artifacts/finance-tracker/dist/public .vercel-out",
  "outputDirectory": ".vercel-out",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
